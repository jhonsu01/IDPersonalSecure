<Window x:Class="IDPersonalSecure.InputPinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PIN" Height="180" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        TextElement.Foreground="{StaticResource TextBrush}">
    <StackPanel Margin="20">
        <TextBlock x:Name="PromptText" Text="Ingresa el PIN" Margin="0,0,0,10"/>
        <PasswordBox x:Name="PinBox" KeyDown="PinBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancelar" Style="{StaticResource GhostButton}" Click="Cancel_Click"/>
            <Button Content="Aceptar" Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
