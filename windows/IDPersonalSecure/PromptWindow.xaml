<Window x:Class="IDPersonalSecure.PromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compartir" Width="420" SizeToContent="Height" MinHeight="190"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        TextElement.Foreground="{StaticResource TextBrush}">
    <StackPanel Margin="20">
        <TextBlock x:Name="PromptText" TextWrapping="Wrap" Margin="0,0,0,10"/>
        <TextBox x:Name="ValueBox" KeyDown="ValueBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancelar" Style="{StaticResource GhostButton}" Click="Cancel_Click"/>
            <Button Content="Aceptar" Click="Ok_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
