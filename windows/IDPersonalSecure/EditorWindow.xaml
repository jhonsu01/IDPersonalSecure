<Window x:Class="IDPersonalSecure.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Documento" Height="640" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        TextElement.Foreground="{StaticResource TextBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock x:Name="HeaderText" Text="Nuevo documento" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

            <TextBlock Text="Nombre"/>
            <TextBox x:Name="NameBox" Margin="0,2,0,10"/>

            <TextBlock Text="Tipo"/>
            <ComboBox x:Name="TypeBox" Margin="0,2,0,10" DisplayMemberPath="Label" SelectedValuePath="Code"/>

            <TextBlock Text="País (ISO 3166-1 alpha-2)"/>
            <TextBox x:Name="CountryBox" MaxLength="2" Margin="0,2,0,10"/>

            <TextBlock Text="Número"/>
            <TextBox x:Name="NumberBox" Margin="0,2,0,10"/>

            <TextBlock Text="Fecha de expedición"/>
            <Grid Margin="0,2,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="IssueBox" Grid.Column="0"/>
                <Button Grid.Column="1" Content="📅" Style="{StaticResource GhostButton}" Margin="6,0,0,0" Click="IssueCalendar_Click"/>
                <Popup x:Name="IssuePopup" PlacementTarget="{Binding ElementName=IssueBox}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="White" TextElement.Foreground="#111827" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                        <Border.Resources>
                            <Style TargetType="Button"/>
                            <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#111827"/></Style>
                        </Border.Resources>
                        <Calendar x:Name="IssueCal" Background="White" Foreground="#111827" SelectedDatesChanged="IssueCal_Changed"/>
                    </Border>
                </Popup>
            </Grid>

            <CheckBox x:Name="HasExpiryBox" Content="¿Tiene vencimiento?" Foreground="{StaticResource TextBrush}"
                      Margin="0,4,0,8" Checked="HasExpiry_Changed" Unchecked="HasExpiry_Changed"/>

            <TextBlock x:Name="ExpiryLabel" Text="Fecha de vencimiento"/>
            <Grid x:Name="ExpiryRow" Margin="0,2,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ExpiryBox" Grid.Column="0"/>
                <Button Grid.Column="1" Content="📅" Style="{StaticResource GhostButton}" Margin="6,0,0,0" Click="ExpiryCalendar_Click"/>
                <Popup x:Name="ExpiryPopup" PlacementTarget="{Binding ElementName=ExpiryBox}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="White" TextElement.Foreground="#111827" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                        <Border.Resources>
                            <Style TargetType="Button"/>
                            <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#111827"/></Style>
                        </Border.Resources>
                        <Calendar x:Name="ExpiryCal" Background="White" Foreground="#111827" SelectedDatesChanged="ExpiryCal_Changed"/>
                    </Border>
                </Popup>
            </Grid>

            <TextBlock Text="Adjunto (PDF o imagen)"/>
            <Grid Margin="0,2,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush2}"
                        BorderThickness="1" CornerRadius="4" Padding="8,6">
                    <TextBlock x:Name="AttachLabel" Text="(ninguno)" Foreground="{StaticResource MutedBrush}"
                               TextTrimming="CharacterEllipsis"/>
                </Border>
                <Button Grid.Column="1" Content="Adjuntar…" Style="{StaticResource GhostButton}" Margin="6,0,0,0" Click="Attach_Click"/>
                <Button Grid.Column="2" Content="Quitar" Style="{StaticResource GhostButton}" Margin="6,0,0,0" Click="RemoveAttach_Click"/>
            </Grid>

            <TextBlock Text="URL fuente (opcional)"/>
            <TextBox x:Name="UrlBox" Margin="0,2,0,10"/>

            <TextBlock Text="Notas"/>
            <TextBox x:Name="NotesBox" Margin="0,2,0,16" AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Style="{StaticResource GhostButton}" Click="Cancel_Click"/>
                <Button Content="Guardar" Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
